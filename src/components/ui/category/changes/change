#!/bin/python3
import os

def replace_string_in_files(directory_path, old_string, new_string):
    """
    Replaces occurrences of old_string with new_string in all files
    within the specified directory and its subdirectories.
    """
    for root, _, files in os.walk(directory_path):
        for file_name in files:
            file_path = os.path.join(root, file_name)
            try:
                with open(file_path, 'r', encoding='utf-8') as f:
                    content = f.read()

                if old_string in content:
                    new_content = content.replace(old_string, new_string)
                    with open(file_path, 'w', encoding='utf-8') as f:
                        f.write(new_content)
                    print(f"Replaced string in: {file_path}")
            except Exception as e:
                print(f"Error processing {file_path}: {e}")

# Example usage:
if __name__ == "__main__":
    target_directory = "./"  # Replace with your directory path
    #string_to_find = "this/utils"
